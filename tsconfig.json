{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src", "tsdown.config.ts", "tests/helpers.test.ts", "tests/uploader.test.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "test"
  ]
}
